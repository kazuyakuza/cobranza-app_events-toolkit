{
  "name": "@cobranza-apps/events-toolkit",
  "version": "0.10.1",
  "description": "NestJS library for standardized NATS+JetStream event handling across Cobranza App microservices",
  "keywords": [
    "nestjs",
    "nats",
    "jetstream",
    "events",
    "messaging",
    "microservices",
    "cobranza-app"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kazuyakuza/cobranza-app_events-toolkit"
  },
  "license": "Unlicense",
  "author": "kazuyakuza",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist/",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "class-validator-jsonschema": "^5.1.0",
    "nats": "^2.29.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "reflect-metadata": "^0.2.2",
    "uuid": "^14.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@nestjs/testing": "^11.1.27",
    "@types/better-sqlite3": "^7.6.13",
    "class-validator-jsonschema": "^5.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.0.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
